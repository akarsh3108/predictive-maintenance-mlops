{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Predictive Maintenance — Serving",
  "uid": "pdm-serving",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Predictions / sec",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(pdm_predictions_total[5m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failure Prediction Rate",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(pdm_predictions_total{outcome=\"failure\"}[5m])) / sum(rate(pdm_predictions_total[5m]))",
          "legendFormat": "failure_rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.10 },
              { "color": "red",    "value": 0.20 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Inference Latency (p50/p95/p99)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(pdm_prediction_latency_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(pdm_prediction_latency_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(pdm_prediction_latency_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Prediction Score Distribution",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(pdm_prediction_score_bucket[15m])))",
          "legendFormat": "median score"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(pdm_prediction_score_bucket[15m])))",
          "legendFormat": "p90 score"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "min": 0, "max": 1 } },
      "description": "Watch for sudden distribution shifts — these often signal data drift or upstream sensor issues before the drift CronJob catches them."
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Model Load Errors (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(pdm_model_load_errors_total[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      }
    }
  ]
}
